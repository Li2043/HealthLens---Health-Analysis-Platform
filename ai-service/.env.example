# Extractor provider: mock (default), openai, deepseek, or regex
EXTRACTOR_PROVIDER=mock

# LLM provider: mock (default), openai, or deepseek
LLM_PROVIDER=mock

# Required when using OpenAI providers
OPENAI_API_KEY=

# Required when LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60

APP_VERSION=dev
APP_ENV=development
ANALYSE_TIMEOUT_SECONDS=30
MAX_INPUT_CHARS=5000
RUN_LIVE_LLM_TESTS=false

# Set true only to expose legacy static UI at /legacy (not for production)
ENABLE_LEGACY_FRONTEND=false
