# Extractor provider: mock (default), openai, or regex
EXTRACTOR_PROVIDER=mock

# LLM provider: mock (default) or openai
LLM_PROVIDER=mock

# Required when using OpenAI providers
OPENAI_API_KEY=

APP_VERSION=dev
APP_ENV=development
ANALYSE_TIMEOUT_SECONDS=30
MAX_INPUT_CHARS=5000
RUN_LIVE_LLM_TESTS=false

# Set true only to expose legacy static UI at /legacy (not for production)
ENABLE_LEGACY_FRONTEND=false
