# HealthLens Platform — environment template (copy to .env, never commit .env)

POSTGRES_DB=healthlens
POSTGRES_USER=healthlens
POSTGRES_PASSWORD=change_me

SPRING_PROFILES_ACTIVE=local
AI_SERVICE_BASE_URL=http://ai-service:8000

VITE_API_BASE_URL=/api
# Docker Compose sets VITE_PROXY_TARGET=http://backend:8080 on the frontend service.
# For frontend on host + backend in Docker, use:
# VITE_PROXY_TARGET=http://localhost:8080

# Local development only. For production, generate a strong secret:
#   PowerShell: .\scripts\generate-jwt-secret.ps1
#   Bash:       ./scripts/generate-jwt-secret.sh
# Then set SPRING_PROFILES_ACTIVE=prod and paste JWT_SECRET into server .env
JWT_SECRET=change-me-use-a-long-random-secret-in-production
JWT_EXPIRATION_MS=86400000

EXTRACTOR_PROVIDER=mock
LLM_PROVIDER=mock
OPENAI_API_KEY=

APP_ENV=development
APP_VERSION=dev
ENABLE_LEGACY_FRONTEND=false
