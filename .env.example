# HealthLens Platform — environment template (copy to .env, never commit .env)

POSTGRES_DB=healthlens
POSTGRES_USER=healthlens
POSTGRES_PASSWORD=change_me

SPRING_PROFILES_ACTIVE=local
AI_SERVICE_BASE_URL=http://ai-service:8000

VITE_API_BASE_URL=/api
# Docker Compose sets VITE_PROXY_TARGET=http://backend:8080 on the frontend service.
# For frontend on host + backend in Docker, use:
# VITE_PROXY_TARGET=http://localhost:8080

# Local development only. For production, generate a strong secret:
#   PowerShell: .\scripts\generate-jwt-secret.ps1
#   Bash:       ./scripts/generate-jwt-secret.sh
# Then set SPRING_PROFILES_ACTIVE=prod and paste JWT_SECRET into server .env
JWT_SECRET=change-me-use-a-long-random-secret-in-production
JWT_EXPIRATION_MS=86400000

# Max analyses per user per UTC day (regular accounts)
ANALYSIS_DAILY_LIMIT=10

# Demo account — auto-created on backend startup for presentations
DEMO_ACCOUNT_ENABLED=true
DEMO_ACCOUNT_EMAIL=demo@healthlens.demo
DEMO_ACCOUNT_PASSWORD=demo1234
DEMO_ANALYSIS_DAILY_LIMIT=20

# Shown on the login page (keep in sync with backend demo account settings)
VITE_DEMO_ACCOUNT_ENABLED=true
VITE_DEMO_ACCOUNT_EMAIL=demo@healthlens.demo
VITE_DEMO_ACCOUNT_PASSWORD=demo1234
VITE_DEMO_ANALYSIS_DAILY_LIMIT=20

EXTRACTOR_PROVIDER=deepseek
LLM_PROVIDER=deepseek
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60

APP_ENV=development
APP_VERSION=dev
ENABLE_LEGACY_FRONTEND=false
